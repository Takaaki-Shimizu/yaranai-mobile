{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "outDir": ".test-dist",
    "rootDir": "lib",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": []
  },
  "include": [
    "lib/dates.ts",
    "lib/usage-buckets.ts",
    "lib/garden/**/*.ts",
    "lib/__tests__/**/*.ts",
    "lib/articles/trigger.ts",
    "lib/articles/state.ts",
    "lib/articles/types.ts",
    "lib/articles/markdown.ts",
    "lib/articles/__tests__/**/*.ts"
  ]
}
